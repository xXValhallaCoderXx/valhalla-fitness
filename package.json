{
  "name": "sheetless",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "db:migrate:local": "supabase db push --local --yes",
    "db:migrate": "supabase db push --db-url \"$SUPABASE_DB_URL\" --yes",
    "db:migrate:dry-run": "supabase db push --db-url \"$SUPABASE_DB_URL\" --dry-run",
    "demo:seed": "node scripts/demo-data.mjs seed",
    "demo:reset": "node scripts/demo-data.mjs reset",
    "demo:refresh": "node scripts/demo-data.mjs refresh",
    "demo:verify": "node scripts/demo-data.mjs verify",
    "demo:list": "node scripts/demo-data.mjs list",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "playwright": "playwright test"
  },
  "dependencies": {
    "@mantine/core": "^9.3.2",
    "@mantine/hooks": "^9.3.2",
    "@mantine/notifications": "9.3.2",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "clsx": "2.1.1",
    "dayjs": "^1.11.21",
    "dexie": "4.4.4",
    "lucide-react": "1.21.0",
    "nitro": "3.0.260610-beta",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "workbox-window": "^7.4.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@playwright/test": "1.57.0",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "22.19.21",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "jsdom": "27.2.0",
    "supabase": "^2.107.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "4.0.15"
  }
}
