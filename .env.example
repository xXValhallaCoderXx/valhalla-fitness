# Supabase API URL for the app server. For local Supabase, use http://127.0.0.1:54321.
SUPABASE_URL=
SUPABASE_ANON_KEY=
APP_ORIGIN=

# Local/demo scripts only. Never expose this to browser/client code.
SUPABASE_SERVICE_ROLE_KEY=

# Remote Postgres connection string used only by migration scripts.
# On Railway, use Supabase's IPv4 transaction pooler URI; never expose this to client code.
SUPABASE_DB_URL=

# Auth policy (server runtime). Defaults derive from NODE_ENV when unset:
#   AUTH_PASSWORD_ENABLED  default = NODE_ENV !== 'production'  (password sign-in/up/reset)
#   AUTH_ALLOWLIST_ENABLED default = NODE_ENV === 'production'  (gate magic links by allowed_emails)
# Production (Railway): set AUTH_PASSWORD_ENABLED=false and AUTH_ALLOWLIST_ENABLED=true.
AUTH_PASSWORD_ENABLED=
AUTH_ALLOWLIST_ENABLED=
